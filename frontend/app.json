{
  "expo": {
    "name": "Son Lokma",
    "slug": "son-lokma",
    "scheme": "askida-yemek",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/son-lokma-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#27ae60"
    },
    "plugins": [
